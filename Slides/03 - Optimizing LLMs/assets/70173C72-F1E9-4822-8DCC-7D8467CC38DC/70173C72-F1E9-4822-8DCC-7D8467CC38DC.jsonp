56640625}},{"text":"Challenges of Deploying LLMs in Production","targetRectangle":{"y":59.995984554290771,"x":33.861657619476318,"width":570.32121093750004,"height":33}},{"text":"High memory and storage demands make deployment costly and complex.","targetRectangle":{"y":246.22682189941406,"x":46.974926471710205,"width":596.2939453125,"height":31.20556640625}},{"text":"Pluralsight-Logo-Stacked-ColorWhite-Fill.png","targetRectangle":{"y":57.457728624343872,"x":838.72973880624363,"width":102.563817675873,"height":47.449788157631701}},{"text":"Resource-Intensive Nature:","targetRectangle":{"y":169.34287005662918,"x":33.600000753998756,"width":234.0703125,"height":31.20556640625}},{"text":"Deployment on high-performance instances can cost upwards of $10,000 per month depending on usage and demand.","targetRectangle":{"y":476.87869358062744,"x":46.974926471710205,"width":842.537109375,"height":62.4111328125}},{"text":"Gráfico 22","targetRectangle":{"y":0,"x":0,"width":960,"height":164}},{"text":"Scalability Issues:","targetRectangle":{"y":284.66879367828369,"x":33.599998950958252,"width":156.076171875,"height":31.20556640625}},{"text":"Large Language Models (LLMs) require significant computational resources for training and inference.","targetRectangle":{"y":207.78485107421875,"x":46.974926471710205,"width":811.458984375,"height":31.20556640625}},{"text":"Balancing load and maintaining low latency is critical for user satisfaction.","targetRectangle":{"y":361.55276584625244,"x":46.974926471710205,"width":584.296875,"height":31.20556640625}},{"text":"Scaling LLMs to handle real-time applications can be challenging.","targetRectangle":{"y":323.11077976226807,"x":46.974926471710205,"width":522.31640625,"height":31.20556640625}},{"text":"Example Costs:","targetRectangle":{"y":399.99475193023682,"x":33.599998950958252,"width":135.0439453125,"height":31.20556640625}}],"baseLayer":{"animations":[],"initialState":{"affineTransform":[1,0,0,1,0,0],"masksToBounds":false,"rotation":0